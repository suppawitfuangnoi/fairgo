{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "NODE_ENV=development pnpm install --frozen-lockfile"
  },
  "deploy": {
    "startCommand": "node_modules/.bin/ts-node --project tsconfig.server.json server.ts",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
