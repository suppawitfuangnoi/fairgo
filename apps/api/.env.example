# ============================================================
# FAIRGO API — Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Aiven PostgreSQL connection string
DATABASE_URL="postgres://avnadmin:PASSWORD@HOST:PORT/defaultdb?sslmode=require"

# ── JWT Secrets (generate with: openssl rand -base64 64) ─────
JWT_SECRET="replace-with-64-char-random-string"
JWT_REFRESH_SECRET="replace-with-different-64-char-random-string"

# ── Server ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── CORS allowed origins ─────────────────────────────────────
ADMIN_WEB_URL="https://admin.fairgo.app"
CUSTOMER_APP_URL="*"

# ── Local development ─────────────────────────────────────────
# Set to "true" when running locally to allow any localhost port
# (flutter run -d chrome uses a random port each time)
# Safe to leave unset in production — only takes effect if NODE_ENV != production
ALLOW_LOCALHOST_CORS="true"
