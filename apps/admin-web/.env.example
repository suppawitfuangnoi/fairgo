# ============================================================
# FAIRGO Admin Web — Environment Variables
# Copy this file to .env.local and fill in real values
# ============================================================

# ── API Backend ───────────────────────────────────────────────
# URL of your deployed API (Vercel or Railway)
NEXT_PUBLIC_API_URL="https://fairgo-api.vercel.app"

# ── Socket.IO Server ─────────────────────────────────────────
# URL of your Railway Socket.IO deployment (separate from REST API)
NEXT_PUBLIC_SOCKET_URL="https://fairgo-socket.up.railway.app"
